/* ========================================
   织念 ZhiNian - 全局设计系统
   ======================================== */

/* --- 色彩体系 --- */
page {
  --primary: #e94560;
  --primary-light: #ff6b81;
  --bg-dark: #0f0f1a;
  --bg-card: #1a1a2e;
  --bg-card-hover: #222240;
  --bg-input: #252542;
  --text-primary: #f0f0f5;
  --text-secondary: #8b8ba3;
  --text-muted: #5a5a72;
  --border-color: #2d2d48;
  --spark-color: #f6b93b;
  --knowledge-color: #4a90d9;
  --emotion-color: #e056fd;
  --experience-color: #7bed9f;
  --success: #2ed573;
  --warning: #ffa502;
  --danger: #ff4757;

  background-color: var(--bg-dark);
  color: var(--text-primary);
  font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Display', 'PingFang SC', 'Helvetica Neue', sans-serif;
  font-size: 28rpx;
  line-height: 1.6;
}

/* --- 布局工具类 --- */
.container {
  padding: 30rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

.flex-row {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.flex-col {
  display: flex;
  flex-direction: column;
}

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

/* --- 卡片组件 --- */
.card {
  background: var(--bg-card);
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid var(--border-color);
  transition: all 0.3s ease;
}

.card:active {
  background: var(--bg-card-hover);
  transform: scale(0.98);
}

.card-glow-spark { box-shadow: 0 8rpx 32rpx rgba(246, 185, 59, 0.15); }
.card-glow-knowledge { box-shadow: 0 8rpx 32rpx rgba(74, 144, 217, 0.15); }
.card-glow-emotion { box-shadow: 0 8rpx 32rpx rgba(224, 86, 253, 0.15); }
.card-glow-experience { box-shadow: 0 8rpx 32rpx rgba(123, 237, 159, 0.15); }

/* --- 文字样式 --- */
.title-lg {
  font-size: 44rpx;
  font-weight: 700;
  color: var(--text-primary);
  letter-spacing: 2rpx;
}

.title-md {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.title-sm {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-primary);
}

.text-secondary {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.text-muted {
  font-size: 22rpx;
  color: var(--text-muted);
}

.text-gradient {
  background: linear-gradient(135deg, var(--primary), var(--primary-light));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

/* --- 标签/徽章 --- */
.tag {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 18rpx;
  border-radius: 20rpx;
  font-size: 20rpx;
  font-weight: 500;
  margin-right: 12rpx;
  margin-bottom: 12rpx;
}

.tag-spark { background: rgba(246, 185, 59, 0.15); color: var(--spark-color); }
.tag-knowledge { background: rgba(74, 144, 217, 0.15); color: var(--knowledge-color); }
.tag-emotion { background: rgba(224, 86, 253, 0.15); color: var(--emotion-color); }
.tag-experience { background: rgba(123, 237, 159, 0.15); color: var(--experience-color); }
.tag-link { background: rgba(233, 69, 96, 0.15); color: var(--primary); }

/* --- 按钮 --- */
.btn-primary {
  background: linear-gradient(135deg, var(--primary), var(--primary-light));
  color: white;
  border: none;
  border-radius: 16rpx;
  padding: 20rpx 40rpx;
  font-size: 28rpx;
  font-weight: 600;
  text-align: center;
}

.btn-primary:active {
  opacity: 0.85;
  transform: scale(0.97);
}

.btn-ghost {
  background: transparent;
  color: var(--text-secondary);
  border: 1rpx solid var(--border-color);
  border-radius: 16rpx;
  padding: 18rpx 36rpx;
  font-size: 26rpx;
}

/* --- 输入框 --- */
.input-box {
  background: var(--bg-input);
  border: 1rpx solid var(--border-color);
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  color: var(--text-primary);
  font-size: 28rpx;
}

.textarea-box {
  background: var(--bg-input);
  border: 1rpx solid var(--border-color);
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  color: var(--text-primary);
  font-size: 28rpx;
  min-height: 200rpx;
  width: 100%;
  box-sizing: border-box;
}

/* --- 动画 --- */
@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(30rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.6; }
}

.fade-in-up {
  animation: fadeInUp 0.5s ease forwards;
}

/* --- 分隔线 --- */
.divider {
  height: 1rpx;
  background: var(--border-color);
  margin: 30rpx 0;
}

/* --- 空状态 --- */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
  color: var(--text-muted);
}

.empty-state .empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
  opacity: 0.5;
}
