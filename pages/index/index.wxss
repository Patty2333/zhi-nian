/* ========================================
   首页样式
   ======================================== */

.header {
  padding: 20rpx 0 40rpx;
}

.header-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.greeting {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 8rpx;
  letter-spacing: 2rpx;
}

.subtitle {
  font-size: 24rpx;
  color: var(--text-muted);
  line-height: 1.5;
}

.avatar-wrap {
  width: 80rpx;
  height: 80rpx;
  background: var(--bg-card);
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx solid var(--border-color);
}

.avatar-icon {
  font-size: 36rpx;
}

/* 统计行 */
.stats-row {
  display: flex;
  align-items: center;
  background: var(--bg-card);
  border-radius: 20rpx;
  padding: 28rpx 36rpx;
  margin-bottom: 40rpx;
  border: 1rpx solid var(--border-color);
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-num {
  font-size: 40rpx;
  font-weight: 700;
}

.stat-label {
  font-size: 22rpx;
  color: var(--text-muted);
  margin-top: 4rpx;
}

.stat-divider {
  width: 1rpx;
  height: 50rpx;
  background: var(--border-color);
}

/* 分区标题 */
.section-title {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.section-sub {
  font-size: 22rpx;
  color: var(--text-muted);
  font-weight: 400;
  margin-left: 12rpx;
}

.see-all {
  font-size: 24rpx;
  color: var(--primary);
  font-weight: 400;
}

/* 分区卡片网格 */
.category-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  margin-bottom: 40rpx;
}

.category-card {
  background: var(--bg-card);
  border-radius: 24rpx;
  padding: 28rpx;
  border: 1rpx solid var(--border-color);
  display: flex;
  flex-direction: column;
  position: relative;
  overflow: hidden;
}

.category-card:active {
  transform: scale(0.96);
  opacity: 0.9;
}

.cat-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.spark-bg { background: rgba(246, 185, 59, 0.15); }
.knowledge-bg { background: rgba(74, 144, 217, 0.15); }
.emotion-bg { background: rgba(224, 86, 253, 0.15); }
.experience-bg { background: rgba(123, 237, 159, 0.15); }

.cat-icon {
  font-size: 34rpx;
}

.cat-info {
  display: flex;
  flex-direction: column;
}

.cat-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 6rpx;
}

.cat-desc {
  font-size: 20rpx;
  color: var(--text-muted);
}

.cat-count {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
}

.count-num {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-muted);
}

/* 最近记录 */
.recent-list {
  margin-bottom: 40rpx;
}

.recent-item {
  padding: 24rpx;
}

.recent-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.recent-time {
  font-size: 20rpx;
  color: var(--text-muted);
}

.recent-content {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.6;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.recent-links {
  margin-top: 14rpx;
}

.link-hint {
  font-size: 20rpx;
  color: var(--primary);
}

/* 空状态提示 */
.quick-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
}

.tip-icon {
  font-size: 64rpx;
  margin-bottom: 20rpx;
  opacity: 0.6;
}

.tip-text {
  font-size: 26rpx;
  color: var(--text-muted);
  text-align: center;
  line-height: 1.6;
}
