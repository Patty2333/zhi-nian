/* 分区通用头部 */
.zone-header {
  display: flex;
  align-items: center;
  margin-bottom: 36rpx;
  padding-bottom: 28rpx;
  border-bottom: 1rpx solid var(--border-color);
}

.zone-icon-wrap {
  width: 80rpx;
  height: 80rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.spark-glow { background: rgba(246, 185, 59, 0.15); }
.knowledge-glow { background: rgba(74, 144, 217, 0.15); }
.emotion-glow { background: rgba(224, 86, 253, 0.15); }
.experience-glow { background: rgba(123, 237, 159, 0.15); }

.zone-icon { font-size: 38rpx; }

.zone-title-area { flex: 1; }

.zone-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-primary);
  display: block;
}

.zone-desc {
  font-size: 22rpx;
  color: var(--text-muted);
  margin-top: 4rpx;
  display: block;
}

.zone-count {
  font-size: 24rpx;
  color: var(--text-muted);
  background: var(--bg-card);
  padding: 8rpx 20rpx;
  border-radius: 16rpx;
}

/* 思维卡片 */
.card-list { padding-bottom: 140rpx; }

.thought-card { position: relative; overflow: hidden; }

.card-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 14rpx;
}

.card-time { font-size: 22rpx; color: var(--text-muted); }

.card-link-badge {
  background: rgba(233, 69, 96, 0.12);
  padding: 4rpx 14rpx;
  border-radius: 12rpx;
  font-size: 18rpx;
  color: var(--primary);
}

.card-content {
  font-size: 28rpx;
  color: var(--text-primary);
  line-height: 1.7;
  display: -webkit-box;
  -webkit-line-clamp: 6;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.card-bottom { margin-top: 18rpx; display: flex; flex-wrap: wrap; gap: 8rpx; }

.card-keywords { display: flex; gap: 10rpx; flex-wrap: wrap; }

.kw-item {
  font-size: 18rpx;
  color: var(--text-muted);
  background: var(--bg-input);
  padding: 4rpx 12rpx;
  border-radius: 10rpx;
}

/* 悬浮按钮 */
.fab {
  position: fixed;
  right: 30rpx;
  bottom: 120rpx;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #f6b93b, #ff9f43);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(246, 185, 59, 0.4);
  z-index: 100;
}

.fab:active { transform: scale(0.9); }

.fab-icon {
  font-size: 48rpx;
  color: white;
  font-weight: 300;
  margin-top: -4rpx;
}
